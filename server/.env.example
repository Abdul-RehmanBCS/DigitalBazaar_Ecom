PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/digital_bazaar
JWT_SECRET=replace_with_secure_secret
CLIENT_URL=http://localhost:5173
STRIPE_SECRET_KEY=sk_test_your_key

# Google OAuth (Console → APIs & Services → Credentials → OAuth 2.0 Client ID)
# Authorized JavaScript origins: http://localhost:5173
# Authorized redirect URIs: not required for Google Identity Services button
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# --- Free AI for chatbot + AI blog generator (use ONE — Groq recommended) ---
# Groq (free): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# OpenAI (optional, paid)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
